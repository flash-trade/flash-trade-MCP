# Flash Trade CLI — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Required ───

# Cluster: mainnet-beta or devnet
FLASH_CLUSTER=devnet

# Solana RPC endpoint (needs decent rate limits — use Helius, Triton, or QuickNode)
FLASH_RPC_URL_DEVNET=https://your-devnet-rpc-endpoint
FLASH_RPC_URL_MAINNET=https://your-mainnet-rpc-endpoint

# ─── Optional ───

# Helius API key (for priority fee estimation)
HELIUS_API_KEY=

# Flash API endpoint (for backup oracle instructions)
FLASH_API_ENDPOINT=https://api.prod.flash.trade

# Pyth Hermes endpoint (for oracle prices — public, no key needed)
HERMES_URL=https://hermes.pyth.network

# Path to Solana keypair file (for importing into CLI)
FLASH_TEST_KEYPAIR=~/.config/solana/id.json
