# Dependencies
node_modules/

# Rust build artifacts
target/

# Build outputs
dist/
builds/
out/

# Environment & secrets (NEVER commit)
.env
.env.*
!.env.example
*.pem
*.key
*.secret

# Solana keypairs (NEVER commit)
id.json
*.keypair.json

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Lock files (bun.lock and Cargo.lock ARE committed for reproducible builds)
# Do NOT add bun.lock or Cargo.lock here

