# Flash Trade API base URL (required)
FLASH_API_URL=http://localhost:3000

# Optional: Override for different environments
# FLASH_API_URL=https://api.flash.trade   # Production
# FLASH_API_URL=https://devnet-api.flash.trade  # Devnet

# Wallet pubkey for transaction building (optional — can also pass per-tool)
# WALLET_PUBKEY=YOUR_WALLET_PUBKEY_HERE

# HTTP timeout in ms (default: 30000)
# FLASH_API_TIMEOUT=30000
