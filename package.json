{
  "name": "@flash-trade/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "flash": "dist/index.js"
  },
  "engines": {
    "bun": ">=1.0"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target node --format esm --minify",
    "build:binary": "bash scripts/build.sh",
    "lint": "bunx oxlint src",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test",
    "ci": "bun run lint && bun run typecheck && bun run test",
    "format": "bunx prettier --write src/",
    "day0": "bun run tests/day0-compat.ts"
  },
  "dependencies": {
    "flash-sdk": "15.4.1",
    "@coral-xyz/anchor": "0.32.1",
    "@solana/web3.js": "1.98.2",
    "@solana/spl-token": "0.4.8",
    "@scure/bip32": "1.6.2",
    "@scure/bip39": "1.5.4",
    "commander": "14.0.3",
    "chalk": "5.4.1",
    "cli-table3": "0.6.5",
    "ky": "1.7.5",
    "bn.js": "5.2.1",
    "bignumber.js": "9.1.2"
  },
  "devDependencies": {
    "@types/bn.js": "5.1.6",
    "@types/bun": "^1.3.10",
    "prettier": "3.4.2",
    "typescript": "5.5.4"
  }
}
